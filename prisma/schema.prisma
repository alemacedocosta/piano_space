generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String              @id @default(cuid())
  name               String?
  email              String?             @unique
  emailVerified      DateTime?           @db.Timestamptz(6)
  image              String?
  createdAt          DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
  password           String?
  paidAt             DateTime?           @db.Timestamptz(6)
  accounts           Account[]
  practiceStreak     PracticeStreak?
  sessions           Session[]
  userProgress       UserProgress[]
  virtualPianoConfig VirtualPianoConfig?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime @db.Timestamptz(6)

  @@unique([identifier, token])
}

model Lesson {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String
  description   String
  level         DifficultyLevel
  videoUrl      String?
  sheetMusicPdf String?
  order         Int
  createdAt     DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime        @default(now()) @updatedAt @db.Timestamptz(6)
  userProgress  UserProgress[]

  @@index([level])
  @@index([order])
}

model Song {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title            String
  composer         String
  difficultyRating Int            @default(1)
  midiFileUrl      String?
  bpmSuggested     Int?
  createdAt        DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  userProgress     UserProgress[]

  @@index([difficultyRating])
}

model UserProgress {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String
  lessonId        String?        @db.Uuid
  songId          String?        @db.Uuid
  status          ProgressStatus @default(Started)
  lastPracticedAt DateTime       @default(now()) @db.Timestamptz(6)
  accuracyScore   Float?         @default(0)
  starsEarned     Int            @default(0)
  createdAt       DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  lesson          Lesson?        @relation(fields: [lessonId], references: [id], onUpdate: NoAction)
  song            Song?          @relation(fields: [songId], references: [id], onUpdate: NoAction)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, lessonId])
  @@unique([userId, songId])
  @@index([userId])
  @@index([status])
}

model PracticeStreak {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String   @unique
  currentStreak         Int      @default(0)
  longestStreak         Int      @default(0)
  totalMinutesPracticed Int      @default(0)
  lastActiveDate        DateTime @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([currentStreak])
}

model VirtualPianoConfig {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String       @unique
  keyLabelMode      KeyLabelMode @default(Note)
  showFingerNumbers Boolean      @default(false)
  themeColorHex     String       @default("#75B390")
  updatedAt         DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

enum DifficultyLevel {
  Beginner
  Intermediate
  Advanced
}

enum ProgressStatus {
  Started
  Completed
  Mastered
}

enum KeyLabelMode {
  Note
  Solfege
}
