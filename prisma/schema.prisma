// Piano space — Prisma Schema
// Banco: PostgreSQL (Supabase)
// Autenticação: NextAuth.js

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Auth (NextAuth padrão) ────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  userProgress      UserProgress[]
  practiceStreak    PracticeStreak?
  virtualPianoConfig VirtualPianoConfig?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Piano space Domain ────────────────────────────────────────────────────────

enum DifficultyLevel {
  Beginner
  Intermediate
  Advanced
}

enum ProgressStatus {
  Started
  Completed
  Mastered
}

enum KeyLabelMode {
  Note    // C, D, E
  Solfege // Dó, Ré, Mi
}

// Lição individual (conteúdo educacional)
model Lesson {
  id             String          @id @default(uuid())
  title          String
  description    String          @db.Text
  level          DifficultyLevel
  videoUrl       String?
  sheetMusicPdf  String?
  order          Int
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  userProgress UserProgress[]

  @@index([level])
  @@index([order])
}

// Música / Peça para prática
model Song {
  id           String   @id @default(uuid())
  title        String
  composer     String
  difficultyRating Int  @default(1)
  midiFileUrl  String?
  bpmSuggested Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userProgress UserProgress[]

  @@index([difficultyRating])
}

// Progresso do usuário (rastreia lições e músicas)
model UserProgress {
  id               String         @id @default(uuid())
  userId           String
  lessonId         String?
  songId           String?
  status           ProgressStatus @default(Started)
  lastPracticedAt  DateTime       @default(now())
  accuracyScore    Float?         @default(0)
  starsEarned      Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  song   Song?   @relation(fields: [songId], references: [id], onDelete: SetNull)

  @@unique([userId, lessonId])
  @@unique([userId, songId])
  @@index([userId])
  @@index([status])
}

// Ofensiva / hábito diário
model PracticeStreak {
  id                   String   @id @default(uuid())
  userId               String   @unique
  currentStreak        Int      @default(0)
  longestStreak        Int      @default(0)
  totalMinutesPracticed Int     @default(0)
  lastActiveDate       DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([currentStreak])
}

// Configurações do teclado virtual
model VirtualPianoConfig {
  id                String       @id @default(uuid())
  userId            String       @unique
  keyLabelMode      KeyLabelMode @default(Note)
  showFingerNumbers Boolean      @default(false)
  themeColorHex     String       @default("#75B390")
  updatedAt         DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
